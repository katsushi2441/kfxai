# OANDA credentials. Use a Practice account first.
OANDA_ACCOUNT_ID=
OANDA_ACCESS_TOKEN=
OANDA_ENVIRONMENT=practice

# paper: OANDA prices + local virtual trades
# practice: submit orders to OANDA Practice
# live: submit real-money orders; requires the exact acknowledgement below
KFXAI_TRADING_MODE=paper
KFXAI_LIVE_ACK=

KFXAI_INSTRUMENTS=USD_JPY,EUR_JPY,EUR_USD,GBP_JPY,AUD_JPY
KFXAI_GRANULARITY=M15
KFXAI_CANDLE_COUNT=240
KFXAI_CYCLE_SECONDS=300
KFXAI_BASE_UNITS=1000
KFXAI_MAX_POSITIONS=3
KFXAI_SIGNAL_THRESHOLD=0.62
KFXAI_MAX_SPREAD_PIPS=2.0
KFXAI_STOP_LOSS_PIPS=25
KFXAI_TAKE_PROFIT_PIPS=40
KFXAI_MAX_DAILY_LOSS_JPY=3000
KFXAI_MAX_HOLD_CANDLES=32
KFXAI_DATABASE=data/kfxai.sqlite3

# rule_based, local_llm, or x402
KFXAI_JUDGMENT_BACKEND=rule_based
KFXAI_OLLAMA_URL=http://127.0.0.1:11434
KFXAI_OLLAMA_MODEL=gemma4:12b-it-qat
KFXAI_BRAIN_URL=
KFXAI_BRAIN_TIMEOUT=330

# Seller-side judgment API. Put an x402 gateway in front of this service.
# rule_based or local_llm; x402 is intentionally forbidden to avoid recursion.
KFXAI_BRAIN_ENGINE=rule_based
KFXAI_BRAIN_HOST=127.0.0.1
KFXAI_BRAIN_PORT=18325

# Keep false unless the API is bound to a trusted network.
KFXAI_ENABLE_CONTROL_API=false

# direction: per-cycle direction model / session: Tokyo-range London-breakout (validated on JPY pairs)
KFXAI_STRATEGY=direction
KFXAI_SESSION_TP_MULT=1.5
KFXAI_SESSION_BUFFER_PIPS=2.0
KFXAI_SESSION_MAX_SL_PIPS=40
KFXAI_SESSION_MIN_RANGE_PIPS=10

# arena: run multiple strategies in parallel with per-strategy ledgers
# roster: session,donchian,rsi_meanrev,ma_cross,llm_analyst (llm_analyst needs kfxbrain)
KFXAI_ARENA_STRATEGIES=session,donchian,rsi_meanrev,ma_cross
